# flip-ai Configuration

# Port to listen on
PORT=3000

# Optional: API Key to protect your proxy
# API_KEY=your_secret_key

# Password for /settings. If omitted, /settings stays locked unless API_KEY is set.
# The import endpoints accept API_KEY, SETTINGS_PASSWORD, or CONFIG_PASSWORD.
# SETTINGS_PASSWORD=your_settings_password

# Default model used when requests send "model": "default".
# DEFAULT_MODEL=mimo-v2.5-pro

# API key required by /v1/*, /api/* and /open-apis/bot/chat.
# You can also configure this in /settings; env takes precedence.
# REQUEST_API_KEY=your_request_api_key

# Xiaomi Mimo session configuration
# Prefer importing the browser session with the extension. These legacy fields
# are still supported when you want to bootstrap auth manually.
SERVICE_TOKEN="seu_service_token_aqui"
USER_ID="seu_user_id_aqui"
XIAOMI_CHATBOT_PH="seu_ph_aqui"

# Alternativa: cookie bruto copiado do navegador/EasyPanel
# O proxy extrai serviceToken, userId e xiaomichatbot_ph automaticamente.
# XIAOMI_COOKIE='serviceToken="..."; userId=...; xiaomichatbot_ph="..."'

# Ativa busca na web do Mimo por padrão em todas as requisições
# DEFAULT_WEB_SEARCH=true

# DeepSeek Web usa Proof-of-Work. O Docker já instala nodejs e inclui o WASM.
# Para execução local fora do Docker, mantenha node no PATH.
# DEEPSEEK_POW_WASM_PATH=internal/assets/sha3_wasm_bg.7b9ca65ddd.wasm

# Official free-tier provider keys.
# Use models like:
# - gemini-3.5-flash
# - groq/llama-3.1-8b-instant
# - openrouter/meta-llama/llama-3.1-8b-instruct:free
# - cf/@cf/meta/llama-3.1-8b-instruct
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=flip-ai
# CLOUDFLARE_API_KEY=
# CLOUDFLARE_ACCOUNT_ID=

# Kilo Code / agent mode: com tools o thinking já vem desligado por padrão.
# Para forçar thinking mesmo com tools:
# AGENT_ENABLE_THINKING=true

# Performance (agent / IDE com tools) — AGENT_FAST_MODE=true por padrão
# AGENT_FAST_MODE=false
# AGENT_MAX_CONTEXT_CHARS=100000
# AGENT_MAX_MESSAGES=20
# AGENT_MAX_TOOL_RESULT_CHARS=6000
# AGENT_SEQUENTIAL_TOOLS=true

# Fluxo recomendado para produção:
# use a extensão do navegador no dashboard para importar sessões autenticadas
# e salvar tudo em data/auth.json automaticamente.
